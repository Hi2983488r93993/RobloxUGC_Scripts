local function getWaveButtonText() 
    local gui = PlayerGui:FindFirstChild("GUI") 
    if gui then 
        local hud = gui:FindFirstChild("HUD") 
        local top = hud and hud:FindFirstChild("Top") 
        local buttons = top and top:FindFirstChild("Buttons") 
        local waveButton = buttons and buttons:FindFirstChild("WaveButton") 
        local textObj = waveButton and waveButton:FindFirstChild("Text") 
        if textObj and textObj:IsA("TextLabel") then 
            return textObj.Text 
        end 
    end 
    return nil 
end 

