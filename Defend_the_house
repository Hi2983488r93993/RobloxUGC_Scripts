-- =======================================================
-- TASK 2: Quét chọn Plot của mình và DESTROY các Plot khác
-- =======================================================
task.spawn(function()
    local workspace = game:GetService("Workspace")
    local plotsFolder = workspace:WaitForChild("Plots")

    -- Hàm đệ quy tìm kiếm sâu từ khóa "touch" hoặc class TouchInterest
    local function hasTouchInterest(object)
        for _, child in ipairs(object:GetDescendants()) do
            if child:IsA("TouchInterest") or string.find(string.lower(child.Name), "touch") then
                return true
            end
        end
        return false
    end

    local allPlots = plotsFolder:GetChildren()
    local myPlot = nil

    -- Duyệt tìm Plot của mình
    for _, plot in ipairs(allPlots) do
        if hasTouchInterest(plot) then
            myPlot = plot
            break
        end
    end

    -- Xóa sổ các Plot không phải của mình
    if myPlot then
        for _, plot in ipairs(allPlots) do
            if plot ~= myPlot then
                plot:Destroy()
            end
        end
    else
        warn("Không tìm thấy Plot nào chứa TouchInterest!")
    end
end)
