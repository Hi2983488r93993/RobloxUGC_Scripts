task.spawn(function() 
    local Players = game:GetService("Players") 
    local localPlayer = Players.LocalPlayer 
    local PlayerGui = localPlayer:WaitForChild("PlayerGui") 
    local VirtualInputManager = game:GetService("VirtualInputManager") 
    
    local hudPath = PlayerGui:WaitForChild("GUI"):WaitForChild("HUD"):WaitForChild("Top"):WaitForChild("WaveSettings") 
    local Button_Speed2 = hudPath:WaitForChild("Speed2") 
    local Button_AutoWave = hudPath:WaitForChild("AutoWave") 
    
    local TARGET_COLOR_SEQUENCE = ColorSequence.new({ 
        ColorSequenceKeypoint.new(0, Color3.new(0, 0.666667, 1)), 
        ColorSequenceKeypoint.new(1, Color3.new(0, 1, 1)) 
    }) 
    
    local function checkColorMatch(gradient) 
        if not gradient or not gradient:IsA("UIGradient") then return false end 
        local currentKeypoints = gradient.Color.Keypoints 
        local targetKeypoints = TARGET_COLOR_SEQUENCE.Keypoints 
        if #currentKeypoints ~= #targetKeypoints then return false end 
        for i = 1, #currentKeypoints do 
            local c1 = currentKeypoints[i] 
            local c2 = targetKeypoints[i] 
            if math.abs(c1.Time - c2.Time) > 0.01 or math.abs(c1.Value.R - c2.Value.R) > 0.01 or math.abs(c1.Value.G - c2.Value.G) > 0.01 or math.abs(c1.Value.B - c2.Value.B) > 0.01 then 
                return false 
            end 
        end 
        return true 
    end 
    
    local function clickButton(instance) 
        if not instance or not instance:IsA("GuiObject") or not instance.Visible then return end 
        pcall(function() 
            local posX = instance.AbsolutePosition.X + (instance.AbsoluteSize.X / 2) 
            local posY = instance.AbsolutePosition.Y + (instance.AbsoluteSize.Y / 2) 
            VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, true, game, 0) 
            task.wait(0.01) 
            VirtualInputManager:SendMouseButtonEvent(posX, posY, 0, false, game, 0) 
            if firesignal then 
                firesignal(instance.MouseButton1Click) 
            end 
        end) 
    end 
    
    while true do 
        -- Kiểm tra và click nút Speed2
        if config.Speed2 then
            pcall(function() 
                local gradientSpeed = Button_Speed2:FindFirstChild("Design"):FindFirstChild("Gradient") 
                if gradientSpeed and checkColorMatch(gradientSpeed) then 
                    clickButton(Button_Speed2) 
                end 
            end) 
        end
        
        -- Kiểm tra và click nút AutoWave
        if config.AutoWaveGrad then
            pcall(function() 
                local gradientAuto = Button_AutoWave:FindFirstChild("Design"):FindFirstChild("Gradient") 
                if gradientAuto and checkColorMatch(gradientAuto) then 
                    clickButton(Button_AutoWave) 
                end 
            end) 
        end
        task.wait(0.1) 
    end 
end) 

