                    end
                end
                -- Nếu không tìm thấy bằng class, thử lấy nút trùng tên "Back" hoặc nút bấm bất kỳ
                if not continueBtn then
                    continueBtn = gameContinueFrame:FindFirstChild("Back") or gameContinueFrame:FindFirstChildOfClass("GuiButton")
                end
            end
            
            -- Biến kiểm tra riêng biệt xem nút Back/Continue (2 Frame chuyển cảnh) có xuất hiện hay không
            local isBackOrContinueVisible = false
            if (backBtn and backBtn.Visible) or (continueBtn and continueBtn.Visible) then
                isBackOrContinueVisible = true
            end
            
            -- Kiểm tra xem bất kỳ nút chuyển màn nào (kể cả coinPlay) đang hiển thị
            local isAnyTransitionButtonVisible = isBackOrContinueVisible or (coinPlayBtn and coinPlayBtn.Visible)
            
            -- 2. Dò tìm bàn cờ giải mìn đang chạy
            local activeGameLayer = getActiveGameLayer()
            local activeBoard = activeGameLayer and activeGameLayer:FindFirstChild("_board")
            
            -- LUẬT ƯU TIÊN MỚI: Nếu thấy nút Back/Continue của 2 Frame chuyển cảnh thì bỏ qua board và click thẳng
            if isBackOrContinueVisible then
