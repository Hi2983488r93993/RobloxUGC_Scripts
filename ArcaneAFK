-- ==========================================================
-- HỆ THỐNG CLICK GUI TOÀN DIỆN (KẾT HỢP TẤT CẢ PHƯƠNG THỨC CLICK)
-- ==========================================================
local function clickGuiObj(instance) 
    if not instance or not instance:IsA("GuiObject") or not instance.Visible then return end 
    
    pcall(function() 
        local events = {"MouseButton1Click", "MouseButton1Down", "MouseButton1Up", "Activated"}
        
        -- Kiểu 1: Sử dụng getconnections (Chạy trực tiếp luồng kết nối của game)
        if getconnections then
            for _, eventName in ipairs(events) do
                local event = instance[eventName]
                if event then
                    for _, connection in ipairs(getconnections(event)) do
                        if connection.Fire then 
                            connection:Fire() 
                        end
                    end
                end
            end
        end
        
        -- Kiểu 2: Sử dụng firesignal (Kích hoạt trực tiếp Event Signal của UI)
        if firesignal then 
            for _, eventName in ipairs(events) do
                local event = instance[eventName]
                if event then
                    firesignal(event)
                end
            end
        end 
    end) 
end

-- Giữ nguyên hàm superClick cũ của hệ thống giải mìn _board
local function superClick(instance) 
    if not instance or not instance:IsA("GuiObject") or not instance.Visible then return end 
    
    pcall(function() 
        if firesignal then 
            firesignal(instance.MouseButton1Click)
            firesignal(instance.MouseButton1Down)
            firesignal(instance.MouseButton1Up)
        end 
    end) 
end

-- Định vị động để không bao giờ bị kẹt tham chiếu cũ khi game reset UI
local function getActiveGameLayer()
    local arcadeFrame = PlayerGui:FindFirstChild("ArcadeScreenGui") and PlayerGui.ArcadeScreenGui:FindFirstChild("ArcadeFrame")
    if not arcadeFrame then return nil end
    
    local play = arcadeFrame:FindFirstChild("Play")
    if not play then return nil end
    
    local bodyLayer = play:FindFirstChild("BodyLayer")
    if not bodyLayer then return nil end
    
    return bodyLayer:FindFirstChild("GameLayer")
end

local config = {
    AutoMinesweeper = true,
    DelayBetweenTurns = 0.4
}

local isProcessing = false
local currentBoardUID = nil
local lastDetectedBoard = nil
local consecutiveStuckCount = 0

-- ==========================================================
-- HỖ TRỢ TOÁN HỌC TẬP HỢP (SET HELPERS)
-- ==========================================================
local function isSubset(setA, setB)
    for key in pairs(setA) do
        if not setB[key] then return false end
    end
    return true
end

local function getSetDifference(setA, setB)
    local diff = {}
    local count = 0
    for key in pairs(setA) do
        if not setB[key] then
            diff[key] = true
            count = count + 1
        end
    end
    return diff, count
end

-- Tự động dò kích thước bàn cờ thực tế
local function detectBoardSize(_board)
    local maxIndex = 5 
    for _, child in ipairs(_board:GetChildren()) do
        if string.match(child.Name, "^t_%d+_%d+$") then
            local x, y = string.match(child.Name, "^t_(%d+)_(%d+)$")
            x = tonumber(x)
            y = tonumber(y)
            if x and x > maxIndex then maxIndex = x end
            if y and y > maxIndex then maxIndex = y end
        end
    end
    return maxIndex
end

-- Chụp hash trạng thái tĩnh để chống click khi đang loang hiệu ứng
local function getBoardStateHash(_board, maxIdx)
    local hash = ""
    for x = 0, maxIdx do
        for y = 0, maxIdx do
            local cell = _board:FindFirstChild("t_"..x.."_"..y)
            if cell then
                local numLabel = cell:FindFirstChild("Num")
                local idleFrame = cell:FindFirstChild("Idle")
                local isNumVisible = numLabel and numLabel.Visible and "1" or "0"
                local isIdleVisible = idleFrame and idleFrame.Visible and "1" or "0"
                local numText = (numLabel and numLabel.Visible) and numLabel.Text or "X"
                hash = hash .. string.format("%s%s%s|", isNumVisible, isIdleVisible, numText)
            else
                hash = hash .. "N|"
            end
        end
    end
    return hash
end

-- ==========================================================
-- CORE LOGIC GIẢI MÌN BẢN CAO THỦ (SET INTERSECTION SOLVER)
-- ==========================================================
local function processMinesweeperLogic(_board)
    if isProcessing then return end
    isProcessing = true

    local maxIdx = detectBoardSize(_board)

    -- Chờ hiệu ứng render hoàn tất
    local state1 = getBoardStateHash(_board, maxIdx)
    task.wait(0.2)
    local state2 = getBoardStateHash(_board, maxIdx)

    if state1 ~= state2 then
        isProcessing = false
        return
    end

    local grid = {}       -- 0: Đóng, 1: Mở, 9: BOM chắc chắn
    local nums = {}       -- Giá trị ô số
    local hitButtons = {} 
    local hasClosedTile = false

    for x = 0, maxIdx do
        grid[x] = {}
        nums[x] = {}
        hitButtons[x] = {}
        for y = 0, maxIdx do
            grid[x][y] = 0 
            nums[x][y] = -1
        end
    end

    -- Bước 1: Đọc trạng thái bàn cờ
    for x = 0, maxIdx do
        for y = 0, maxIdx do
            local cell = _board:FindFirstChild("t_"..x.."_"..y)
            if cell then
                local hit = cell:FindFirstChild("_hit")
                local numLabel = cell:FindFirstChild("Num")
                local idleFrame = cell:FindFirstChild("Idle")
                
                hitButtons[x][y] = hit

                local isNumVisible = numLabel and numLabel.Visible
                local isIdleVisible = idleFrame and idleFrame.Visible

                if not isNumVisible and isIdleVisible then
                    grid[x][y] = 0
                    hasClosedTile = true
                else
                    grid[x][y] = 1 
                    if isNumVisible then
                        local val = tonumber(numLabel.Text)
                        if val and val > 0 then
                            nums[x][y] = val 
                        end
                    end
                end
            end
        end
    end

    if not hasClosedTile then 
        isProcessing = false
        return 
    end

    -- Vòng lặp giải liên tục cho đến khi không tìm thêm được thông tin mới ở lượt này
    local changed = true
    while changed do
        changed = false

        -- Bước 2: Luật cơ bản (Single-cell solver)
        for x = 0, maxIdx do
            for y = 0, maxIdx do
                if nums[x][y] > 0 then
                    local numBombs = nums[x][y]
                    local closedNeighbors = {}
                    local flaggedCount = 0

                    for dx = -1, 1 do
                        for dy = -1, 1 do
                            if not (dx == 0 and dy == 0) then
                                local nx, ny = x + dx, y + dy
                                if nx >= 0 and nx <= maxIdx and ny >= 0 and ny <= maxIdx then
                                    if grid[nx][ny] == 0 then
                                        table.insert(closedNeighbors, {x = nx, y = ny})
                                    elseif grid[nx][ny] == 9 then
                                        flaggedCount = flaggedCount + 1
                                    end
                                end
                            end
                        end
                    end

                    -- Nếu số ô đóng bằng số mìn chưa tìm thấy
                    if #closedNeighbors > 0 and #closedNeighbors == (numBombs - flaggedCount) then
                        for _, cell in ipairs(closedNeighbors) do
                            grid[cell.x][cell.y] = 9
                            changed = true
                            print(string.format("[DÒ MÌN] Phát hiện BOM cơ bản tại: t_%d_%d", cell.x, cell.y))
                        end
                    end
                end
            end
        end

        -- Bước 3: ĐỘNG CƠ CAO THỦ - GIẢI THEO TẬP HỢP (Set Solver)
        local constraints = {}
        for x = 0, maxIdx do
            for y = 0, maxIdx do
                if nums[x][y] > 0 then
                    local numBombs = nums[x][y]
                    local unopened = {}
                    local knownMines = 0

                    for dx = -1, 1 do
                        for dy = -1, 1 do
                            if not (dx == 0 and dy == 0) then
                                local nx, ny = x + dx, y + dy
                                if nx >= 0 and nx <= maxIdx and ny >= 0 and ny <= maxIdx then
                                    local key = nx .. "_" .. ny
                                    if grid[nx][ny] == 0 then
                                        unopened[key] = {x = nx, y = ny}
                                    elseif grid[nx][ny] == 9 then
                                        knownMines = knownMines + 1
                                    end
                                end
                            end
                        end
                    end

                    local remainingMines = numBombs - knownMines
                    local unopenedCount = 0
                    for _ in pairs(unopened) do unopenedCount = unopenedCount + 1 end

                    if unopenedCount > 0 then
                        table.insert(constraints, {
                            unopened = unopened,
                            mines = remainingMines,
                            count = unopenedCount,
                            origin = {x = x, y = y}
                        })
                    end
                end
            end
        end

        -- So sánh chéo các cặp phương trình tập hợp (Double-Constraint Check)
        for i = 1, #constraints do
            for j = 1, #constraints do
                if i ~= j then
                    local c1 = constraints[i]
                    local c2 = constraints[j]

                    -- Nếu tập c1 là tập con của c2 (c1 nằm hoàn toàn trong c2)
                    if isSubset(c1.unopened, c2.unopened) then
                        local diffSet, diffCount = getSetDifference(c2.unopened, c1.unopened)
                        if diffCount > 0 then
                            local diffMines = c2.mines - c1.mines

                            -- TRƯỜNG HỢP 1: Hiệu số mìn bằng 0 -> Toàn bộ ô trong hiệu là AN TOÀN
                            if diffMines == 0 then
                                for key in pairs(diffSet) do
                                    local coords = c2.unopened[key]
                                    -- Đánh dấu đặc biệt là an toàn chắc chắn (gán giá trị tạm = -2) để click sau
                                    if grid[coords.x][coords.y] == 0 then
                                        grid[coords.x][coords.y] = -2 
                                        changed = true
                                        print(string.format("[CAO THỦ] Suy luận AN TOÀN tại t_%d_%d nhờ so sánh tập hợp", coords.x, coords.y))
                                    end
                                end
                            
                            -- TRƯỜNG HỢP 2: Hiệu số mìn bằng đúng số ô -> Toàn bộ ô trong hiệu chắc chắn là BOM
                            elseif diffMines == diffCount then
                                for key in pairs(diffSet) do
                                    local coords = c2.unopened[key]
                                    if grid[coords.x][coords.y] == 0 then
                                        grid[coords.x][coords.y] = 9
                                        changed = true
                                        print(string.format("[CAO THỦ] Suy luận BOM tại t_%d_%d nhờ so sánh tập hợp", coords.x, coords.y))
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end

    -- Bước 4: Thực thi hành động Click dựa trên kết quả giải thuật toán
    local actionsTaken = false

    -- 4.1: Click các ô chắc chắn an toàn từ suy luận toán cao cấp (giá trị -2)
    for x = 0, maxIdx do
        for y = 0, maxIdx do
            if grid[x][y] == -2 then
                local targetBtn = hitButtons[x][y]
                if targetBtn and targetBtn.Visible then
                    print(string.format("[KÍCH HOẠT CAO THỦ] Click ô an toàn tuyệt đối: t_%d_%d", x, y))
                    superClick(targetBtn)
                    grid[x][y] = 1
                    actionsTaken = true
                end
            end
        end
    end

    -- 4.2: Nếu không có ô an toàn cao cấp, quét lại luật cơ bản để click
    if not actionsTaken then
        for x = 0, maxIdx do
            for y = 0, maxIdx do
                if nums[x][y] > 0 then
                    local numBombs = nums[x][y]
                    local closedNeighbors = {}
                    local flaggedBombs = 0

                    for dx = -1, 1 do
                        for dy = -1, 1 do
                            if not (dx == 0 and dy == 0) then
                                local nx, ny = x + dx, y + dy
                                if nx >= 0 and nx <= maxIdx and ny >= 0 and ny <= maxIdx then
                                    if grid[nx][ny] == 0 then
                                        table.insert(closedNeighbors, {x = nx, y = ny})
                                    elseif grid[nx][ny] == 9 then
                                        flaggedBombs = flaggedBombs + 1
                                    end
                                end
                            end
                        end
                    end

                    if flaggedBombs == numBombs and #closedNeighbors > 0 then
                        for _, cell in ipairs(closedNeighbors) do
                            local targetBtn = hitButtons[cell.x][cell.y]
                            if targetBtn and targetBtn.Visible and grid[cell.x][cell.y] == 0 then
                                print(string.format("[LOG - AN TOÀN] Click ô: t_%d_%d", cell.x, cell.y))
                                superClick(targetBtn)
                                grid[cell.x][cell.y] = 1
                                actionsTaken = true
                            end
                        end
                    end
                end
            end
        end
    end

    -- Bước 5: BỨC TƯỜNG CUỐI CÙNG - XỬ LÝ CLICK ĐẠI 50/50 KHI BẾ TẮC HOÀN TOÀN
    if not actionsTaken then
        print("[LOG - THẾ BÍ] Cao thủ bó tay! Bắt đầu tính toán phân tích xác suất thông minh...")

        local candidates = {} 
        for x = 0, maxIdx do
            for y = 0, maxIdx do
                local targetBtn = hitButtons[x][y]
                if targetBtn and targetBtn.Visible and grid[x][y] == 0 then
                    local hazardScore = 0
                    local adjacentNumbersCount = 0

                    for dx = -1, 1 do
                        for dy = -1, 1 do
                            if not (dx == 0 and dy == 0) then
                                local nx, ny = x + dx, y + dy
                                if nx >= 0 and nx <= maxIdx and ny >= 0 and ny <= maxIdx then
                                    if grid[nx][ny] == 1 and nums[nx][ny] > 0 then
                                        adjacentNumbersCount = adjacentNumbersCount + 1
                                        hazardScore = hazardScore + nums[nx][ny]
                                    end
                                end
                            end
                        end
                    end

                    table.insert(candidates, {
                        btn = targetBtn,
                        x = x,
                        y = y,
                        score = hazardScore,
                        adjCount = adjacentNumbersCount
                    })
                end
            end
        end

        if #candidates > 0 then
            table.sort(candidates, function(a, b)
                if a.score == b.score then
                    return a.adjCount < b.adjCount
                end
                return a.score < b.score
            end)

            local bestChoice = candidates[1]
            print(string.format("[LOG - 50/50] Click phá băng ô có độ rủi ro thấp nhất: t_%d_%d (Độ nguy hiểm: %d)", bestChoice.x, bestChoice.y, bestChoice.score))
            superClick(bestChoice.btn)
            actionsTaken = true
            consecutiveStuckCount = 0
        else
            consecutiveStuckCount = consecutiveStuckCount + 1
            print(string.format("[HỆ THỐNG] Không tìm thấy ô trống khả dụng. Lượt kẹt: %d", consecutiveStuckCount))
        end
    else
        consecutiveStuckCount = 0
    end

    if actionsTaken then
        task.wait(0.2)
    end
    isProcessing = false
end

