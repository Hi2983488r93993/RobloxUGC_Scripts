                elseif continueBtn and continueBtn.Visible then
                    print(string.format("[CHUYỂN MÀN - ƯU TIÊN] Phát hiện nút Tiếp tục (%s)! Bỏ qua board và bấm...", continueBtn.Name))
                    clickGuiObj(continueBtn)
                end
                
            -- Nếu không có Back/Continue hiển thị, xử lý bàn cờ như bình thường
            elseif activeBoard then
                -- Kiểm tra nếu board cũ bị hủy (không còn nằm trong game) hoặc xuất hiện board mới hoàn toàn
                local isBoardExpired = lastDetectedBoard and not lastDetectedBoard:IsDescendantOf(game)
                
                if not currentBoardUID or lastDetectedBoard ~= activeBoard or isBoardExpired then
                    lastDetectedBoard = activeBoard
                    currentBoardUID = tostring(math.random(100000, 999999))
                    isProcessing = false
                    consecutiveStuckCount = 0
                    print(string.format("[HỆ THỐNG] Đã phát hiện và kết nối động bàn cờ mới (ID: %s)!", currentBoardUID))
                    task.wait(0.4) -- Chờ game nạp xong các node UI t_x_y
                end
                
                -- Phòng vệ treo phân tích dữ liệu
                if consecutiveStuckCount >= 2 then
                    print("[HỆ THỐNG - WARN] Script bị nghẽn phân tích. Tiến hành ép reset kết nối...")
                    currentBoardUID = nil
                    isProcessing = false
                    consecutiveStuckCount = 0
                    task.wait(0.2)
                else
                    pcall(function()
                        processMinesweeperLogic(activeBoard)
                    end)
                end
            else
                -- Kịch bản: BÀN CỜ CHƯA XUẤT HIỆN (_board == nil)
                if currentBoardUID then
                    print("[HỆ THỐNG] Đang chờ bàn cờ tiếp theo...")
                    currentBoardUID = nil
                    lastDetectedBoard = nil
                    isProcessing = false
                    consecutiveStuckCount = 0
                end
                
                -- 2.1. Nếu có bất kỳ nút chuyển màn nào đang hiện hữu, thực hiện click ngay lập tức
                if isAnyTransitionButtonVisible then
                    -- Bổ sung điều kiện chặn tuyệt đối: Không bấm coinPlay khi gameContinueFrame đang hiển thị
                    local isContinueFrameVisible = gameContinueFrame and gameContinueFrame.Visible
                    
                    if coinPlayBtn and coinPlayBtn.Visible and not isContinueFrameVisible then
                        print("[CHUYỂN MÀN] Đang ấn nút Bắt đầu chơi (coinPlay)...")
                        clickGuiObj(coinPlayBtn)
                    elseif backBtn and backBtn.Visible then
                        print("[CHUYỂN MÀN] Đang ấn nút Trở về (Back)...")
                        clickGuiObj(backBtn)
                    elseif continueBtn and continueBtn.Visible then
                        print(string.format("[CHUYỂN MÀN] Đang ấn nút Tiếp tục bên trong GameContinue (%s)...", continueBtn.Name))
                        clickGuiObj(continueBtn)
                    end
                else
                    -- 2.2. Không có nút chuyển màn và chưa có _board -> Thực hiện di chuyển nhân vật và kích hoạt ProximityPrompt
                    local character = LocalPlayer.Character
                    local humanoidRootPart = character and character:FindFirstChild("HumanoidRootPart")
                    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
                    
                    if humanoidRootPart and humanoid then
                        local targetPosition = Vector3.new(34, 4, 40)
                        local currentPos = humanoidRootPart.Position
                        local distance = (currentPos - targetPosition).Magnitude
                        
                        -- Di chuyển đến vị trí đích (Khoảng cách chấp nhận sai số <= 1.5 studs)
                        if distance > 1.5 then
                            humanoid:MoveTo(targetPosition)
                        else
                            -- Khi đã đứng đúng vị trí đích, kích hoạt ProximityPrompt của máy chơi game Arcade_Minesweeper
